{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "description": "Primary coding agent using Claude",
      "prompt": "{file:.opencode/prompts/build.txt}",
      "permission": {
        "task": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "description": "Planning agent using Claude",
      "prompt": "{file:.opencode/prompts/plan.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "review": {
      "description": "Reviews code and plans for correctness, quality, and alignment with the plan using OpenAI",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:.opencode/prompts/review.txt}",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  }
}
